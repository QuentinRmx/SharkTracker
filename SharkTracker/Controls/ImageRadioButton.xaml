<UserControl x:Class="SharkTracker.Controls.ImageRadioButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:SharkTracker.Controls"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid>
        <Button x:Name="BtnBilgewater" Background="Transparent" Foreground="Transparent">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Image Height="70" Width="70" Source="../Data/en_us/img/regions/icon-bilgewater.png"></Image>
            </StackPanel>
        </Button>
    </Grid>
</UserControl>
