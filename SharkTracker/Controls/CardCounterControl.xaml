<UserControl x:Class="SharkTracker.Controls.CardCounterControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:SharkTracker.Controls"
             mc:Ignorable="d"
             d:DesignHeight="Auto" d:DesignWidth="Auto">
    <StackPanel Height="Auto" Orientation="Horizontal">
        <Border Width="25" CornerRadius="1" BorderBrush="FloralWhite" BorderThickness="1">
            <Button Margin="-1" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="14"
                    FontWeight="Bold"
                    BorderThickness="0" Background="Transparent"
                    Foreground="GhostWhite" Content=" - " Click="Decrement" />
        </Border>
        <Label x:Name="quantityLabel" Foreground="White" FontSize="14"/>
        <Border Width="25" CornerRadius="1" BorderBrush="FloralWhite" BorderThickness="1">
            <Button Margin="-1" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="14"
                    FontWeight="Bold"
                    BorderThickness="0" Background="Transparent"
                    Foreground="GhostWhite" Content=" + " Click="Increment" />
        </Border>
    </StackPanel>
</UserControl>
